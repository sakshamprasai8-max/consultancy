datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  CONSULTANT
  ADMIN
}

enum ApplicationStatus {
  PENDING
  DOCUMENT_SUBMITTED
  ADMISSION_OFFERED
  VISA_APPLIED
  VISA_APPROVED
  VISA_REJECTED
  COMPLETED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  RESCHEDULED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  CONVERTED
  LOST
}

enum ContactType {
  GENERAL
  COUNSELING
  SCHOLARSHIP
  APPLICATION
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

enum EventType {
  ONLINE
  IN_PERSON
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  role               Role           @default(STUDENT)
  googleId           String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  // Relations
  profile            Profile?
  applications       Application[]
  documents          Document[]
  notifications      Notification[]
  reviews            Review[]
  
  // As a Consultant
  assignedLeads      Lead[]         @relation("ConsultantLeads")
  createdNotes       LeadNote[]     @relation("AuthorNotes")
  
  // As a Student or Consultant in Appointments
  studentAppointments    Appointment[]  @relation("StudentAppointments")
  consultantAppointments  Appointment[]  @relation("ConsultantAppointments")
}

model Profile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  dateOfBirth          DateTime?
  gender               String?
  address              String?
  passportNumber       String?
  currentQualification String?
  preferredCountry     String?
  preferredSubject     String?
  testType             String?  // IELTS, TOEFL, GRE, GMAT etc.
  testScore            String?
  visaStatus           String?
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Country {
  id           String        @id @default(uuid())
  name         String        @unique
  slug         String        @unique
  description  String
  image        String?       // Cover photo
  requirements String        // Markdown or Text of requirements
  visas        String        // Details of student visa
  active       Boolean       @default(true)
  featured     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  universities University[]
  scholarships Scholarship[]
}

model University {
  id           String        @id @default(uuid())
  name         String        @unique
  slug         String        @unique
  description  String
  logo         String?
  image        String?
  countryId    String
  website      String?
  ranking      Int?
  courses      String[]      // List of top courses offered
  requirements String        // Text of requirements
  active       Boolean       @default(true)
  featured     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  country      Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  applications Application[]
  scholarships Scholarship[]
}

model Application {
  id           String            @id @default(uuid())
  studentId    String
  universityId String
  program      String
  status       ApplicationStatus @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  student      User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  university   University        @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

model Document {
  id        String         @id @default(uuid())
  studentId String
  name      String
  type      String         // Transcript, Resume, Passport, Statement of Purpose etc.
  url       String
  publicId  String         // Cloudinary public ID for deletion
  status    DocumentStatus @default(PENDING)
  remarks   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  student   User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Appointment {
  id           String            @id @default(uuid())
  studentId    String
  consultantId String
  title        String
  description  String?
  dateTime     DateTime
  duration     Int               @default(30) // in minutes
  status       AppointmentStatus @default(SCHEDULED)
  meetLink     String?           // Google Meet link
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  student      User              @relation("StudentAppointments", fields: [studentId], references: [id], onDelete: Cascade)
  consultant   User              @relation("ConsultantAppointments", fields: [consultantId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id                String     @id @default(uuid())
  firstName         String
  lastName          String
  email             String     @unique
  phone             String?
  status            LeadStatus @default(NEW)
  source            String     @default("WEBSITE") // WEBSITE, CAMPAIGN, REFERRAL
  interestedCountry String?
  interestedService String?
  assignedToId      String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  assignedTo        User?      @relation("ConsultantLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes             LeadNote[]
  followups         LeadFollowup[]
}

model LeadNote {
  id         String   @id @default(uuid())
  leadId     String
  content    String
  createdById String
  createdAt  DateTime @default(now())

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("AuthorNotes", fields: [createdById], references: [id], onDelete: Cascade)
}

model LeadFollowup {
  id          String   @id @default(uuid())
  leadId      String
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   // MD or Rich HTML content
  coverImage  String?
  category    String
  tags        String[]
  published   Boolean  @default(true)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  dateTime      DateTime
  location      String
  type          EventType @default(ONLINE)
  image         String?
  capacity      Int      @default(100)
  registrations EventRegistration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Scholarship {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String
  amount       String   // e.g. "$10,000", "50% Tuition Waiver"
  deadline     DateTime
  eligibility  String
  countryId    String
  universityId String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  country      Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)
  university   University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
}

model Review {
  id             String       @id @default(uuid())
  studentId      String
  rating         Int          @default(5)
  title          String
  content        String
  universityName String?
  countryName    String?
  program        String?
  status         ContactStatus @default(NEW) // Approved reviews can be fetched by public API
  createdAt      DateTime     @default(now())

  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(NEW)
  type      ContactType   @default(GENERAL)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
