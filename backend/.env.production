# Production Database (Update with your production DB credentials)
DATABASE_URL="postgresql://postgres:your_secure_password@postgres:5432/educonsultpro?schema=public"

# Security (CHANGE THESE TO LONG RANDOM STRINGS)
JWT_SECRET="generate-a-long-random-string-for-production-security-secret"
JWT_REFRESH_SECRET="generate-another-long-random-string-for-refresh-token"

# Environment
PORT=5000
NODE_ENV=production

# URLs (Update with your domain)
FRONTEND_URL=https://educonsultpro.com
